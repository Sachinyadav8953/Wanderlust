<% layout("/listings/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col col-6 offset-3">
        <h3>Sign Up</h3>
        <form method="post" action="/signup">
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" placeholder="Enter email" class="form-control" required>
            </div>

            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input id="username" name="username" type="text" placeholder="Enter username" class="form-control" required>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" placeholder="Enter password" class="form-control" required>
            </div>

            <button type="submit" class="btn btn-primary add-btn">Sign Up</button>

        </form>
    </div>

</div>